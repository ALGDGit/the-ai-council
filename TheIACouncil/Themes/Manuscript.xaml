<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Popups del sistema (p. ej. desplegable ComboBox): nunca fondo claro -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF252018" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFF4EBD8" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF2E261F" />

    <!-- Paleta -->
    <Color x:Key="Color.Window.Deep">#FF0E0C0A</Color>
    <Color x:Key="Color.Window.Mid">#FF15100D</Color>
    <Color x:Key="Color.Window.Light">#FF1B1511</Color>
    <Color x:Key="Color.Gold">#FFC9A227</Color>
    <Color x:Key="Color.Gold.Bright">#FFE8C547</Color>
    <Color x:Key="Color.Gold.Dim">#FF8B6914</Color>

    <SolidColorBrush x:Key="Bg.Window" Color="{StaticResource Color.Window.Mid}" />
    <SolidColorBrush x:Key="Bg.Nav" Color="#FF1E1814" />
    <SolidColorBrush x:Key="Bg.Field" Color="#FF2A231C" />
    <!-- Paneles: marrones profundos (texto siempre claro encima) -->
    <SolidColorBrush x:Key="Bg.Page" Color="#FF282018" />
    <SolidColorBrush x:Key="Fg.OnDark" Color="#FFF4EBD8" />
    <SolidColorBrush x:Key="Fg.OnPage" Color="#FFF4EBD8" />
    <SolidColorBrush x:Key="Fg.Muted" Color="#FFC4B8A8" />
    <SolidColorBrush x:Key="Accent" Color="{StaticResource Color.Gold}" />
    <SolidColorBrush x:Key="Trim.Gold" Color="{StaticResource Color.Gold.Dim}" />

    <SolidColorBrush x:Key="Input.Parchment" Color="#FF353028" />
    <SolidColorBrush x:Key="Input.Ink" Color="#FFF6EDE0" />
    <SolidColorBrush x:Key="Input.Wood" Color="#FF3A3028" />
    <SolidColorBrush x:Key="Input.GoldLine" Color="#FFB8944A" />
    <SolidColorBrush x:Key="Input.GoldDim" Color="{StaticResource Color.Gold.Dim}" />
    <SolidColorBrush x:Key="Input.CheckFill" Color="#FF454038" />

    <LinearGradientBrush x:Key="Grad.Bg.Window" StartPoint="0,0" EndPoint="1,1">
        <!-- Mismo tono base: una esquina algo más clara y la opuesta más oscura -->
        <GradientStop Color="{StaticResource Color.Window.Light}" Offset="0" />
        <GradientStop Color="{StaticResource Color.Window.Deep}" Offset="1" />
    </LinearGradientBrush>

    <!-- Cartelas / paneles con relieve (sin planos «blancuzcos») -->
    <LinearGradientBrush x:Key="Grad.Bg.Panel" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF3A322A" Offset="0" />
        <GradientStop Color="#FF221C16" Offset="0.48" />
        <GradientStop Color="#FF2E261E" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Bg.Card" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E8382E28" Offset="0" />
        <GradientStop Color="#E8181410" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Nav.Rail" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF2A221C" Offset="0" />
        <GradientStop Color="#FF14110E" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Btn.Wood" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF5A4A3E" Offset="0" />
        <GradientStop Color="#FF342A22" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Btn.Wood.Hover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF6E5C4E" Offset="0" />
        <GradientStop Color="#FF40342C" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Btn.Primary" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF7A622C" Offset="0" />
        <GradientStop Color="#FF453618" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Btn.Primary.Hover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF8F7234" Offset="0" />
        <GradientStop Color="#FF52421C" Offset="1" />
    </LinearGradientBrush>

    <!-- Scrollbar (mismo lenguaje visual: madera oscura + acento dorado suave) -->
    <SolidColorBrush x:Key="Scroll.Track" Color="#221A140F" />
    <SolidColorBrush x:Key="Scroll.Thumb" Color="#AA8B6914" />
    <SolidColorBrush x:Key="Scroll.Thumb.Hover" Color="#CCB8944A" />
    <SolidColorBrush x:Key="Scroll.Thumb.Pressed" Color="#E0C9A227" />
    <SolidColorBrush x:Key="Scroll.Thumb.Disabled" Color="#557A6A52" />

    <Style x:Key="ScrollBarLineButtonStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Thumb">
        <Setter Property="Background" Value="{StaticResource Scroll.Thumb}" />
        <Setter Property="BorderBrush" Value="#90E8C547" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource Scroll.Thumb.Hover}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource Scroll.Thumb.Pressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource Scroll.Thumb.Disabled}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource Scroll.Track}" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarLineButtonStyle}"
                                              Command="ScrollBar.PageUpCommand" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb MinHeight="28" MinWidth="28" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarLineButtonStyle}"
                                              Command="ScrollBar.PageDownCommand" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="PART_Track" Property="LayoutTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sombras: x:Shared="False" para poder usar la misma clave en varios elementos -->
    <DropShadowEffect x:Key="Fx.Shadow.Card"
                      BlurRadius="22"
                      Direction="270"
                      ShadowDepth="6"
                      Opacity="0.55"
                      Color="#FF000000"
                      x:Shared="False" />

    <DropShadowEffect x:Key="Fx.Shadow.Btn"
                      BlurRadius="12"
                      Direction="270"
                      ShadowDepth="4"
                      Opacity="0.5"
                      Color="#FF000000"
                      x:Shared="False" />

    <DropShadowEffect x:Key="Fx.Shadow.Soft"
                      BlurRadius="28"
                      Direction="270"
                      ShadowDepth="2"
                      Opacity="0.35"
                      Color="#FF000000"
                      x:Shared="False" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Grad.Bg.Window}" />
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.4" Color="#FF000000" Direction="270" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
    </Style>

    <Style x:Key="BodyDark" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="24" />
    </Style>

    <Style x:Key="BodyPage" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="24" />
    </Style>

    <Style x:Key="Muted" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Fg.Muted}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource Fg.Muted}" />
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0,10,0,4" />
    </Style>

    <!-- Carril lateral (menú) -->
    <Style x:Key="NavRail" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Grad.Nav.Rail}" />
        <Setter Property="BorderBrush" Value="#448B6914" />
        <Setter Property="BorderThickness" Value="0,0,2,0" />
        <Setter Property="Effect" Value="{StaticResource Fx.Shadow.Soft}" />
    </Style>

    <!-- Cartela central (oscuro con volumen) -->
    <Style x:Key="PagePanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Grad.Bg.Panel}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="28" />
        <Setter Property="BorderBrush" Value="{StaticResource Trim.Gold}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Effect" Value="{StaticResource Fx.Shadow.Card}" />
    </Style>

    <!-- Paneles de partida (oscuro con ribete) -->
    <Style x:Key="GameCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Grad.Bg.Card}" />
        <Setter Property="BorderBrush" Value="#99C9A227" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Effect" Value="{StaticResource Fx.Shadow.Card}" />
    </Style>

    <!-- TextBox pergamino -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource Input.Ink}" />
        <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,11" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SelectionBrush" Value="#99C9A227" />
        <Setter Property="SelectionTextBrush" Value="#FF120E0A" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Wood"
                            Background="{StaticResource Input.Wood}"
                            CornerRadius="8"
                            Padding="2"
                            Effect="{StaticResource Fx.Shadow.Btn}">
                        <Border x:Name="GoldFrame"
                                Background="{StaticResource Input.GoldDim}"
                                CornerRadius="7"
                                Padding="1">
                            <Border x:Name="InnerLight"
                                    Background="{StaticResource Input.Parchment}"
                                    CornerRadius="6">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              Focusable="False" />
                            </Border>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="GoldFrame" Property="Background" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Wood" Property="Opacity" Value="0.98" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="InnerLight" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Registros (deliberación, impostor): sin marco pergamino ni ScrollViewer anidado que recorte el texto -->
    <Style x:Key="ReadOnlyLogTextBox"
           TargetType="TextBox"
           BasedOn="{x:Null}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="CaretBrush" Value="Transparent" />
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="SelectionBrush" Value="#33C9A227" />
        <Setter Property="SelectionTextBrush" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"
                                  Focusable="False" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="Background" Value="{StaticResource Input.Parchment}" />
        <Setter Property="Foreground" Value="{StaticResource Input.Ink}" />
        <Setter Property="BorderBrush" Value="{StaticResource Trim.Gold}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="ComboBorder"
                                Grid.ColumnSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True" />

                        <ContentPresenter x:Name="ContentSite"
                                          Grid.Column="0"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          IsHitTestVisible="False" />

                        <Path Grid.Column="1"
                              Data="M 0,1 L 5,6 L 10,1"
                              Stroke="{StaticResource Accent}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Margin="0,0,12,0"
                              SnapsToDevicePixels="True"
                              IsHitTestVisible="False" />

                        <ToggleButton Grid.ColumnSpan="2"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PopupAnimation="Fade">
                            <Border Background="#FF252018"
                                    BorderBrush="{StaticResource Trim.Gold}"
                                    BorderThickness="2"
                                    CornerRadius="6"
                                    MinWidth="{Binding ActualWidth, ElementName=ComboBorder}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    SnapsToDevicePixels="True"
                                    Effect="{StaticResource Fx.Shadow.Card}">
                                <ScrollViewer Margin="2"
                                              SnapsToDevicePixels="True"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              CanContentScroll="True"
                                              Background="Transparent">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="#FF363028" />
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF484038" />
                <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#668B6914" />
                <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="0,8,0,8" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid x:Name="cbRoot">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="SealOuter"
                                Width="24"
                                Height="24"
                                VerticalAlignment="Center"
                                Background="{StaticResource Input.Wood}"
                                CornerRadius="6"
                                Padding="2"
                                Effect="{StaticResource Fx.Shadow.Btn}">
                            <Border x:Name="SealGold"
                                    Background="{StaticResource Input.GoldDim}"
                                    CornerRadius="5"
                                    Padding="1">
                                <Border x:Name="SealFace"
                                        Background="{StaticResource Input.CheckFill}"
                                        CornerRadius="4">
                                    <Viewbox Width="13"
                                             Height="13"
                                             Stretch="Uniform"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Margin="1">
                                        <Canvas Width="16"
                                                Height="16"
                                                SnapsToDevicePixels="True">
                                            <Path x:Name="CheckMark"
                                                  Data="M 2.5 8 L 6 12 L 13.5 3"
                                                  Stroke="{StaticResource Input.GoldDim}"
                                                  StrokeThickness="1.85"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Visibility="Collapsed" />
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </Border>
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          Margin="12,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SealGold" Property="Background" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SealGold" Property="Background" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="SealFace" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="cbRoot" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="{StaticResource Trim.Gold}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="14,18,14,14" />
        <Setter Property="Margin" Value="0,0,0,16" />
        <Setter Property="Background" Value="#FF201A14" />
        <Setter Property="Effect" Value="{StaticResource Fx.Shadow.Soft}" />
    </Style>

    <!-- Botón secundario (madera + filete dorado + relieve) -->
    <Style x:Key="NavBtn" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="Padding" Value="18,13" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Outer"
                            CornerRadius="10"
                            BorderThickness="2"
                            BorderBrush="{StaticResource Trim.Gold}"
                            Background="{StaticResource Grad.Btn.Wood}"
                            Effect="{StaticResource Fx.Shadow.Btn}"
                            Padding="0">
                        <Border x:Name="InnerEdge"
                                CornerRadius="8"
                                Margin="2"
                                BorderThickness="1,1,1,0"
                                BorderBrush="#35FFFFFF"
                                Background="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{StaticResource Grad.Btn.Wood.Hover}" />
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Outer" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Outer" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón principal (oro / énfasis) -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
        <Setter Property="Foreground" Value="#FFFFF8E8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="18,13" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Outer"
                            CornerRadius="10"
                            BorderThickness="2"
                            BorderBrush="#FFE8C547"
                            Background="{StaticResource Grad.Btn.Primary}"
                            Effect="{StaticResource Fx.Shadow.Btn}"
                            Padding="0">
                        <Border CornerRadius="8"
                                Margin="2"
                                BorderThickness="1,1,1,0"
                                BorderBrush="#55FFFFFF"
                                Background="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{StaticResource Grad.Btn.Primary.Hover}" />
                            <Setter TargetName="Outer" Property="BorderBrush" Value="#FFFFE08A" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Outer" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Outer" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botón icono cuadrado (trofeo, etc.) -->
    <Style x:Key="IconNavBtn" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Fg.OnDark}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Outer"
                            CornerRadius="12"
                            BorderThickness="2"
                            BorderBrush="{StaticResource Trim.Gold}"
                            Background="{StaticResource Grad.Btn.Wood}"
                            Effect="{StaticResource Fx.Shadow.Btn}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{StaticResource Grad.Btn.Wood.Hover}" />
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Outer" Property="Opacity" Value="0.88" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Hyperlink">
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#FFFFE8A0" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
