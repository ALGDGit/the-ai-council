<UserControl x:Class="TheIACouncil.Views.AchievementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Top"
                    Style="{StaticResource PagePanel}"
                    Padding="20,16"
                    Margin="0,0,0,14">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               FontSize="28"
                               Margin="0,0,12,0"
                               Text="🏆" />
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource H2}"
                                   Text="Logros" />
                        <TextBlock Style="{StaticResource BodyPage}"
                                   Opacity="0.85"
                                   Margin="0,6,0,0"
                                   Text="Desbloquea hitos jugando y configurando el consejo." />
                    </StackPanel>
                </DockPanel>
            </Border>

            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        Margin="0,14,0,0">
                <Button Content="← Volver al menú"
                        Style="{StaticResource NavBtn}"
                        Click="BackClick" />
            </StackPanel>

            <Border Style="{StaticResource PagePanel}"
                    Padding="12,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              MaxHeight="420">
                    <StackPanel x:Name="AchievementRows" />
                </ScrollViewer>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
