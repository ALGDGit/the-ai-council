<UserControl x:Class="TheIACouncil.Views.PrisonerRiddleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24"
               LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Acertijo del prisionero"
                           Style="{StaticResource H1}"
                           FontSize="24" />
                <TextBlock Style="{StaticResource BodyDark}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Text="Dos puertas: libertad o muerte. Dos guardianes: uno siempre dice la verdad y otro siempre miente. Solo puedes hacer una pregunta, luego eliges izquierda o derecha." />
            </StackPanel>
        </Border>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="0,12,0,0">
            <Button x:Name="NewRoundButton"
                    Content="Nueva ronda"
                    Style="{StaticResource PrimaryBtn}"
                    HorizontalContentAlignment="Center"
                    Click="NewRoundClick" />
            <Button Content="← Modos"
                    Style="{StaticResource NavBtn}"
                    HorizontalContentAlignment="Center"
                    Click="BackClick" />
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource GameCard}"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Tu pregunta unica"
                               Style="{StaticResource Muted}"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="QuestionBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="74"
                             MaxHeight="130" />
                    <StackPanel Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <Button x:Name="AskButton"
                                Content="Preguntar a los guardianes"
                                Style="{StaticResource PrimaryBtn}"
                                HorizontalContentAlignment="Center"
                                Click="AskClick" />
                    </StackPanel>
                    <TextBlock x:Name="StatusLine"
                               Style="{StaticResource Muted}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource GameCard}"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <DockPanel LastChildFill="True"
                                   Margin="0,0,0,8">
                            <Border Width="64"
                                    Height="64"
                                    DockPanel.Dock="Left"
                                    Margin="0,0,10,0"
                                    CornerRadius="32"
                                    BorderBrush="{StaticResource Trim.Gold}"
                                    BorderThickness="2"
                                    ClipToBounds="True"
                                    Background="#302018">
                                <Image x:Name="GuardAPortrait"
                                       Stretch="UniformToFill" />
                            </Border>
                            <TextBlock x:Name="GuardALabel"
                                       Text="Guardia A"
                                       Style="{StaticResource H2}"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <Border Height="1"
                                Margin="0,0,0,8"
                                Background="#55604B2A" />
                        <ScrollViewer x:Name="GuardAReplyScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="220">
                            <TextBox x:Name="GuardAReply"
                                     Style="{StaticResource ReadOnlyLogTextBox}" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource GameCard}"
                        Margin="8,0,0,0">
                    <StackPanel>
                        <DockPanel LastChildFill="True"
                                   Margin="0,0,0,8">
                            <Border Width="64"
                                    Height="64"
                                    DockPanel.Dock="Left"
                                    Margin="0,0,10,0"
                                    CornerRadius="32"
                                    BorderBrush="{StaticResource Trim.Gold}"
                                    BorderThickness="2"
                                    ClipToBounds="True"
                                    Background="#302018">
                                <Image x:Name="GuardBPortrait"
                                       Stretch="UniformToFill" />
                            </Border>
                            <TextBlock x:Name="GuardBLabel"
                                       Text="Guardia B"
                                       Style="{StaticResource H2}"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                        <Border Height="1"
                                Margin="0,0,0,8"
                                Background="#55604B2A" />
                        <ScrollViewer x:Name="GuardBReplyScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="220">
                            <TextBox x:Name="GuardBReply"
                                     Style="{StaticResource ReadOnlyLogTextBox}" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Grid.ColumnSpan="2"
                        VerticalAlignment="Bottom"
                        Margin="0,14,0,0"
                        Style="{StaticResource PagePanel}">
                    <StackPanel>
                        <TextBlock Text="Elige una puerta"
                                   Style="{StaticResource H2}"
                                   FontSize="18"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button x:Name="LeftDoorButton"
                                    Content="Puerta izquierda"
                                    Style="{StaticResource PrimaryBtn}"
                                    HorizontalContentAlignment="Center"
                                    IsEnabled="False"
                                    Click="LeftDoorClick" />
                            <Button x:Name="RightDoorButton"
                                    Content="Puerta derecha"
                                    Style="{StaticResource NavBtn}"
                                    HorizontalContentAlignment="Center"
                                    IsEnabled="False"
                                    Click="RightDoorClick" />
                        </StackPanel>
                        <TextBlock x:Name="ResultLine"
                                   Style="{StaticResource BodyDark}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
