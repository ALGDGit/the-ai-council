<UserControl x:Class="TheIACouncil.Views.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.Resources>
            <!-- Tinta bermellón con relieve de cera -->
            <LinearGradientBrush x:Key="VermillionWaxTitleBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#FFD65A5A" Offset="0" />
                <GradientStop Color="#FFB22E2E" Offset="0.45" />
                <GradientStop Color="#FF7F1515" Offset="1" />
            </LinearGradientBrush>
        </Grid.Resources>

        <!-- Menú centrado en la pantalla -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="440"
                    Margin="32">
            <Grid HorizontalAlignment="Center"
                  Margin="0,0,0,22">
                <Ellipse Width="300"
                         Height="108"
                         Fill="#44A32020"
                         Stroke="#66D65A5A"
                         StrokeThickness="1.2">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="18"
                                          ShadowDepth="2"
                                          Opacity="0.55"
                                          Color="#AA2C0909" />
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="252"
                         Height="74"
                         Fill="#20FFB8B8"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Margin="20,12,0,0" />
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Consejo"
                               Style="{StaticResource H1}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource VermillionWaxTitleBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,2">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="8"
                                              ShadowDepth="1"
                                              Opacity="0.72"
                                              Color="#FF3D0909"
                                              Direction="270" />
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="de las IAs"
                               Style="{StaticResource Muted}"
                               FontFamily="Georgia"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#FFC66A6A"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <TextBlock Style="{StaticResource H2}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Text="Pregunta al concilio" />
            <TextBlock Style="{StaticResource BodyDark}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Opacity="0.88"
                       Margin="0,10,0,26"
                       Text="Escribe una cuestión y escucha a cada hermano del consejo resumirla; al final votarán SÍ o NO. Configura antes tus claves de API o modelos locales." />

            <Button Content="Jugar"
                    Style="{StaticResource PrimaryBtn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    MinHeight="44"
                    Click="PlayClick" />
            <Button Content="Configuración"
                    Style="{StaticResource NavBtn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    MinHeight="44"
                    Click="ConfigClick" />
            <Button Content="Acerca de"
                    Style="{StaticResource NavBtn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    MinHeight="44"
                    Click="AboutClick" />
            <Button Content="Salir"
                    Style="{StaticResource NavBtn}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    MinHeight="44"
                    Margin="0,18,0,0"
                    Click="ExitClick" />
        </StackPanel>

        <!-- Logros: esquina superior derecha -->
        <Button Width="58"
                Height="58"
                Padding="0"
                Style="{StaticResource IconNavBtn}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="20,24"
                ToolTip="Logros"
                Click="AchievementsClick">
            <TextBlock Text="🏆"
                       FontSize="30"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Button>
    </Grid>
</UserControl>
