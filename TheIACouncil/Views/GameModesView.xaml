<UserControl x:Class="TheIACouncil.Views.GameModesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Border Style="{StaticResource PagePanel}"
                MaxWidth="860"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Modos de juego"
                           Style="{StaticResource H1}"
                           FontSize="24"
                           Margin="0,0,0,16" />
                <TextBlock Text="Elige como quieres consultar al consejo."
                           Style="{StaticResource Muted}"
                           Margin="0,0,0,18" />

                <UniformGrid Columns="2">
                    <Border Background="#331E1814"
                            BorderBrush="{StaticResource Trim.Gold}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,8,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Concilio clasico"
                                           Style="{StaticResource H2}"
                                           FontSize="18"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Modo actual: deliberacion en cadena y veredicto final SI/NO."
                                           Style="{StaticResource BodyDark}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12" />
                            </StackPanel>
                            <Button Grid.Row="1"
                                    Content="Jugar este modo"
                                    Style="{StaticResource PrimaryBtn}"
                                    HorizontalContentAlignment="Center"
                                    Click="ClassicModeClick" />
                        </Grid>
                    </Border>

                    <Border Background="#331E1814"
                            BorderBrush="{StaticResource Trim.Gold}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="8,0,0,12"
                            Opacity="0.95">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Acertijo del prisionero"
                                           Style="{StaticResource H2}"
                                           FontSize="18"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Dos guardianes, dos puertas, una sola pregunta. Una IA dira siempre la verdad y la otra siempre mentira."
                                           Style="{StaticResource BodyDark}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12" />
                            </StackPanel>
                            <Button Grid.Row="1"
                                    Content="Jugar este modo"
                                    Style="{StaticResource PrimaryBtn}"
                                    HorizontalContentAlignment="Center"
                                    Click="PrisonerModeClick" />
                        </Grid>
                    </Border>
                </UniformGrid>

                <UniformGrid Columns="2">
                    <Border Background="#331E1814"
                            BorderBrush="{StaticResource Trim.Gold}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,8,12"
                            Opacity="0.95">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="El impostor"
                                           Style="{StaticResource H2}"
                                           FontSize="18"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Nuevo modo social de deduccion. Pronto descubriremos quien miente en el consejo."
                                           Style="{StaticResource BodyDark}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12" />
                            </StackPanel>
                            <Button Grid.Row="1"
                                    Content="Jugar este modo"
                                    Style="{StaticResource PrimaryBtn}"
                                    HorizontalContentAlignment="Center"
                                    Click="ImpostorModeClick" />
                        </Grid>
                    </Border>
                    <Border Background="Transparent"
                            BorderThickness="0"
                            Margin="8,0,0,12" />
                </UniformGrid>

                <Button Content="← Menú principal"
                        Style="{StaticResource NavBtn}"
                        HorizontalAlignment="Left"
                        Margin="0,10,0,0"
                        Click="BackClick" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
