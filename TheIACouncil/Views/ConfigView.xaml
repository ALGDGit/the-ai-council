<UserControl x:Class="TheIACouncil.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24"
               LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Configuración"
                           Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Muted}"
                           Margin="0,8,0,0">
                    <Run Text="APIs en la nube: modelo desde listas desplegables. Ollama: " />
                    <Hyperlink NavigateUri="https://ollama.com"
                               RequestNavigate="OllamaLink_Click">
                        <Run Text="ollama.com" />
                    </Hyperlink>
                    <Run Text=" — actualiza modelos locales y marca cuáles del consejo." />
                </TextBlock>
            </StackPanel>
        </Border>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="0,14,0,0">
            <Button Content="Guardar"
                    Style="{StaticResource PrimaryBtn}"
                    Click="SaveClick" />
            <Button Content="← Menú"
                    Style="{StaticResource NavBtn}"
                    Click="BackClick" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch">
            <StackPanel>
                <GroupBox Header="Concilio — paralelismo (Ollama / GPU)">
                    <StackPanel>
                        <Label Content="Máximo de llamadas al modelo a la vez" />
                        <TextBox x:Name="MaxConcurrentLlmBox"
                                 ToolTip="Entre 1 y 32. Valores bajos (2–3) suelen evitar errores CUDA u OOM con varias IAs en la misma GPU." />
                        <TextBlock Style="{StaticResource Muted}"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Text="Si al jugar con muchos hermanos ves fallos de CUDA, baja este número: las peticiones se encolan y se ejecutan por tandas." />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="OpenAI">
                    <StackPanel>
                        <CheckBox x:Name="OpenAiEnabled" Content="Activado" />
                        <Label Content="Clave API" />
                        <TextBox x:Name="OpenAiKey" />
                        <Label Content="Modelo" />
                        <ComboBox x:Name="OpenAiModelCombo"
                                  IsEditable="False" />
                        <Label Content="Base URL" />
                        <TextBox x:Name="OpenAiBase" />
                        <Label Content="Personalidad del hermano" />
                        <ComboBox x:Name="OpenAiPersonality" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Anthropic">
                    <StackPanel>
                        <CheckBox x:Name="AnthropicEnabled" Content="Activado" />
                        <Label Content="Clave API" />
                        <TextBox x:Name="AnthropicKey" />
                        <Label Content="Modelo" />
                        <ComboBox x:Name="AnthropicModelCombo"
                                  IsEditable="False" />
                        <Label Content="Base URL" />
                        <TextBox x:Name="AnthropicBase" />
                        <Label Content="Personalidad" />
                        <ComboBox x:Name="AnthropicPersonality" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Google Gemini">
                    <StackPanel>
                        <CheckBox x:Name="GeminiEnabled" Content="Activado" />
                        <Label Content="Clave API" />
                        <TextBox x:Name="GeminiKey" />
                        <Label Content="Modelo" />
                        <ComboBox x:Name="GeminiModelCombo"
                                  IsEditable="False" />
                        <Label Content="Base URL (opcional)" />
                        <TextBox x:Name="GeminiBase" />
                        <Label Content="Personalidad" />
                        <ComboBox x:Name="GeminiPersonality" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="xAI Grok">
                    <StackPanel>
                        <CheckBox x:Name="GrokEnabled" Content="Activado" />
                        <Label Content="Clave API" />
                        <TextBox x:Name="GrokKey" />
                        <Label Content="Modelo" />
                        <ComboBox x:Name="GrokModelCombo"
                                  IsEditable="False" />
                        <Label Content="Base URL" />
                        <TextBox x:Name="GrokBase" />
                        <Label Content="Personalidad" />
                        <ComboBox x:Name="GrokPersonality" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Mistral">
                    <StackPanel>
                        <CheckBox x:Name="MistralEnabled" Content="Activado" />
                        <Label Content="Clave API" />
                        <TextBox x:Name="MistralKey" />
                        <Label Content="Modelo" />
                        <ComboBox x:Name="MistralModelCombo"
                                  IsEditable="False" />
                        <Label Content="Base URL" />
                        <TextBox x:Name="MistralBase" />
                        <Label Content="Personalidad" />
                        <ComboBox x:Name="MistralPersonality" />
                    </StackPanel>
                </GroupBox>

                <!-- Ollama: varios modelos concurrentes — UI distinta -->
                <GroupBox Header="Ollama (local) — varios hermanos">
                    <StackPanel>
                        <CheckBox x:Name="OllamaEnabled" Content="Activado" />
                        <Label Content="URL base del daemon (típico http://localhost:11434)" />
                        <TextBox x:Name="OllamaBase" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,6,0,0">
                            <Button Content="Actualizar modelos locales"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0"
                                    Click="OllamaProbeClick" />
                        </StackPanel>

                        <Label Content="Filtrar lista"
                               Margin="0,14,0,0" />
                        <TextBox x:Name="OllamaFilter"
                                 Margin="0,0,0,8"
                                 ToolTip="Oculta modelos que no coincidan"
                                 TextChanged="OllamaFilter_TextChanged" />

                        <Label Content="Modelos en esta máquina — marca los que participan y asigna personalidad a cada hermano" />
                        <Border Background="{StaticResource Bg.Field}"
                                BorderBrush="#443A3228"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8">
                            <ScrollViewer MaxHeight="280"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="OllamaModelsPanel" />
                            </ScrollViewer>
                        </Border>

                        <Label Content="Personalidad por defecto" />
                        <ComboBox x:Name="OllamaPersonality" />

                        <TextBlock x:Name="OllamaProbeStatus"
                                   Style="{StaticResource Muted}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
