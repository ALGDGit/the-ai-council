<UserControl x:Class="TheIACouncil.Views.PlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             HorizontalContentAlignment="Stretch"
             VerticalContentAlignment="Stretch">
    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="160" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="20,20,20,12">
            <Button Content="← Menú"
                    Style="{StaticResource NavBtn}"
                    Margin="0"
                    Click="BackClick" />
            <Button x:Name="RunButton"
                    Content="Enviar al consejo"
                    Style="{StaticResource PrimaryBtn}"
                    Margin="10,0,0,0"
                    Click="RunClick" />
        </StackPanel>

        <Border x:Name="CouncilRosterHost"
                Grid.Row="1"
                Margin="20,0,20,12"
                Visibility="Visible">
            <Border Style="{StaticResource PagePanel}"
                    Padding="14,12">
                <StackPanel>
                    <TextBlock Text="El concilio"
                               Style="{StaticResource Muted}"
                               Margin="0,0,0,8" />
                    <WrapPanel x:Name="CouncilRosterPanel"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.Row="2"
                Margin="20,0,20,10">
            <StackPanel>
                <TextBlock Text="Tu pregunta"
                           Style="{StaticResource Muted}"
                           Margin="0,0,0,6" />
                <TextBox x:Name="QuestionBox"
                         AcceptsReturn="False"
                         KeyDown="QuestionBoxKeyDown"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="72"
                         MaxHeight="140"
                         FontSize="15" />
                <TextBlock x:Name="StatusLine"
                           Style="{StaticResource Muted}"
                           Margin="0,8,0,0"
                           MinHeight="22" />
            </StackPanel>
        </Border>

        <!-- Zona de juego: deliberación y veredicto (el voto se lee en los recuadros del concilio) -->
        <Grid Grid.Row="3"
              Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280" />
                <ColumnDefinition Width="*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <Border x:Name="DeliberationHost"
                    Grid.Column="0"
                    Style="{StaticResource GameCard}"
                    Margin="0,0,10,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock FontFamily="Georgia"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg.OnDark}"
                                   Margin="0,0,0,4"
                                   Text="Deliberación — razonamiento de cada hermano" />
                    </StackPanel>
                    <ScrollViewer x:Name="DeliberationScroll"
                                  Margin="0,4,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="DeliberationLogPanel" />
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border x:Name="VerdictHost"
                    Grid.Column="1"
                    Style="{StaticResource GameCard}"
                    Margin="10,0,0,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock FontFamily="Georgia"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Accent}"
                                   Margin="0,0,0,8"
                                   Text="Veredicto del Concilio" />
                        <TextBlock x:Name="VerdictActivityLine"
                                   Style="{StaticResource Muted}"
                                   Margin="0,0,0,8"
                                   Text=""
                                   Visibility="Collapsed" />

                        <Border x:Name="VerdictSceneHost"
                                MaxHeight="240"
                                Margin="0,0,0,10"
                                HorizontalAlignment="Stretch"
                                Background="#12000000"
                                CornerRadius="8"
                                ClipToBounds="True"
                                Visibility="Collapsed">
                            <Image x:Name="VerdictSceneImage"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Center"
                                   Opacity="0"
                                   Stretch="Uniform" />
                        </Border>
                    </StackPanel>
                    <ScrollViewer x:Name="VerdictScroll"
                                  Margin="0,4,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="VerdictLogPanel" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Escena de inicio: mesa / estrado (fade aleatorio) -->
        <Border x:Name="OpeningSceneHost"
                Grid.RowSpan="4"
                Panel.ZIndex="100"
                Background="#DD000000"
                Visibility="Collapsed">
            <Image x:Name="OpeningSceneImage"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   MaxWidth="920"
                   MaxHeight="560"
                   Opacity="0"
                   Stretch="Uniform" />
        </Border>
    </Grid>
</UserControl>
