<Window x:Class="TheIACouncil.Windows.NoticeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mensaje"
        Width="440"
        MinWidth="340"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Padding="22"
            Background="Transparent">
        <Border Style="{StaticResource PagePanel}"
                Padding="4">
            <Border Background="Transparent"
                    CornerRadius="10"
                    Padding="24,22"
                    BorderBrush="#44C9A227"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="❧"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Accent}"
                               Margin="0,0,0,8"
                               Opacity="0.9" />
                    <TextBlock x:Name="TitleLine"
                               FontFamily="Georgia"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Fg.OnPage}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <TextBlock x:Name="Body"
                               Style="{StaticResource BodyPage}"
                               TextAlignment="Center"
                               Margin="0,0,0,18" />
                    <Button Content="Entendido"
                            Style="{StaticResource PrimaryBtn}"
                            HorizontalAlignment="Center"
                            MinWidth="140"
                            Margin="0"
                            IsDefault="True"
                            Click="OkClick" />
                </StackPanel>
            </Border>
        </Border>
    </Border>
</Window>
